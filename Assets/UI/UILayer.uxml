<ui:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" noNamespaceSchemaLocation="../../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <ui:Label text="Score: " name="ScoreLabel" style="top: 5%; align-items: auto; align-self: center; font-size: 16px; color: rgb(255, 255, 255); -unity-text-outline-color: rgb(0, 0, 0); -unity-text-outline-width: 0; -unity-font-style: normal; background-color: rgb(0, 0, 0); border-top-width: 2px; border-right-width: 2px; border-bottom-width: 2px; border-left-width: 2px; border-top-left-radius: 10px; border-top-right-radius: 10px; border-bottom-right-radius: 10px; border-bottom-left-radius: 10px; border-left-color: rgb(255, 216, 138); border-right-color: rgb(255, 216, 138); border-top-color: rgb(255, 216, 138); border-bottom-color: rgb(255, 216, 138);"/>
    <ui:Button text="Restart" name="RestartButton" style="justify-content: flex-start; align-items: stretch; align-self: center; align-content: flex-start; top: 50%; position: absolute; left: auto; font-size: 20px; -unity-font-style: bold;"/>
</ui:UXML>
